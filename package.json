{
  "name": "alien-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Browser automation MCP extension",
  "workspaces": [
    "packages/mcp-server",
    "packages/chrome-extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "build:server": "npm run build -w packages/mcp-server",
    "build:extension": "npm run build -w packages/chrome-extension",
    "test:server": "npm run test -w packages/mcp-server",
    "test:extension": "npm run test -w packages/chrome-extension"
  }
}
