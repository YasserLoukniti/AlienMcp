{
  "manifest_version": 3,
  "name": "AlienMcp - Browser Automation for AI",
  "version": "1.0.0",
  "description": "Connect AI agents to your browser. Screenshot, navigate, click, execute JS, read pages, fill forms, watch network - all via MCP protocol.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "debugger",
    "webRequest",
    "offscreen",
    "storage",
    "alarms",
    "tabGroups",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AlienMcp"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; connect-src 'self' ws://localhost:* http://localhost:*; object-src 'none';"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
